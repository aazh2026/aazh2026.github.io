{
  "ci": {
    "collect": {
      "url": [
        "https://aazh2026.github.io/",
        "https://aazh2026.github.io/aise-series/",
        "https://aazh2026.github.io/archive/",
        "https://aazh2026.github.io/loop-engineering/",
        "https://aazh2026.github.io/claude-skills-complete-guide/",
        "https://aazh2026.github.io/agent-os-five-layer-architecture/"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.9 }],
        "categories:accessibility": ["error", { "minScore": 0.8 }],
        "categories:best-practices": ["error", { "minScore": 0.9 }],
        "categories:seo": ["error", { "minScore": 0.85 }],

        "largest-contentful-paint": ["warn", { "maxNumericValue": 2500 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 300 }],
        "speed-index": ["warn", { "maxNumericValue": 3000 }],

        "interactive": ["off"],
        "uses-long-cache-ttl": ["off"],
        "csp-xss": ["off"]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}

